# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://zylora_owner:[password]@ep-[pooler-id].neon.tech/neondb?sslmode=require"

# ─── Neon (Infra CLI/API) ──────────────────────────────
NEON_API_KEY=

# ─── Auth (NextAuth.js v5) ─────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ─── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=

# ─── Cache (Upstash Redis) ─────────────────────────────
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ─── Queue / Cron (Upstash QStash) ─────────────────────
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
